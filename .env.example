# Copiez ce fichier en .env et completez les valeurs.

# Securite
SECRET_KEY=changez-moi-en-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# URL du frontend (lien dans les emails de reinitialisation)
FRONTEND_URL=http://localhost:5173

# CORS : origines autorisees a appeler l'API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Base de donnees (laisser vide => SQLite ; en prod : postgres://...)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Email (Mailtrap pour le developpement)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@biblioteca.local
